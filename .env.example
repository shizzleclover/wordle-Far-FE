# --- Local dev (default) ---
# Leave unset: Vite proxies /api to localhost:3001; socket uses hostname:3001.
# VITE_SERVER_URL=http://localhost:3001
# VITE_API_URL=http://localhost:3001

# --- Production (Vercel + Railway) ---
# Set BOTH in Vercel → Project → Settings → Environment Variables (Production).
# Use your Railway public URL with https, no trailing slash.
#
# VITE_SERVER_URL=https://wordle-far-be-production.up.railway.app
# VITE_API_URL=https://wordle-far-be-production.up.railway.app
